# ==============================================================================
# Pixel Prompt v2 — Backend Environment Variables
#
# Copy to .env.deploy for SAM parameter overrides or set directly in Lambda.
# Variables without defaults are REQUIRED for operation.
# ==============================================================================

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-west-2                     # AWS region for S3/CloudFront/Bedrock
S3_BUCKET=                               # REQUIRED: S3 bucket for sessions and gallery
CLOUDFRONT_DOMAIN=                       # REQUIRED: CloudFront distribution domain for CDN URLs

# ── Gemini (Google) ───────────────────────────────────────────────────────────
GEMINI_ENABLED=true                      # Enable Gemini model
GEMINI_API_KEY=                          # Google Gemini API key
GEMINI_MODEL_ID=gemini-3.1-flash-image-preview  # Gemini image model

# ── Nova Canvas (Amazon Bedrock) ──────────────────────────────────────────────
# Auth uses the Lambda execution role's bedrock:InvokeModel permission.
# No API key is required.
NOVA_ENABLED=true                        # Enable Amazon Nova Canvas model
NOVA_MODEL_ID=amazon.nova-canvas-v1:0    # Bedrock model identifier

# ── OpenAI (DALL-E 3) ─────────────────────────────────────────────────────────
# DALL-E 3 is used for generation. Iteration/outpaint operations use
# gpt-image-1 internally because DALL-E 3 does not support images.edit.
OPENAI_ENABLED=true                      # Enable OpenAI model
OPENAI_API_KEY=                          # OpenAI API key
OPENAI_MODEL_ID=dall-e-3                 # OpenAI image generation model

# ── Adobe Firefly ─────────────────────────────────────────────────────────────
# Auth uses OAuth2 client credentials (no static API key).
FIREFLY_ENABLED=true                     # Enable Adobe Firefly model
FIREFLY_CLIENT_ID=                       # Firefly OAuth2 client ID
FIREFLY_CLIENT_SECRET=                   # Firefly OAuth2 client secret
FIREFLY_MODEL_ID=firefly-image-5         # Firefly model identifier

# ── Prompt Enhancement ────────────────────────────────────────────────────────
PROMPT_MODEL_PROVIDER=openai             # Provider for prompt enhancement (openai or google_gemini)
PROMPT_MODEL_ID=gpt-4o                   # Model ID for prompt enhancement
PROMPT_MODEL_API_KEY=                    # API key for prompt enhancement model

# ── Rate Limiting ─────────────────────────────────────────────────────────────
GLOBAL_LIMIT=1000                        # Global hourly request limit
IP_LIMIT=50                              # Per-IP daily request limit
IP_INCLUDE=                              # Comma-separated IPs exempt from rate limiting

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=*                    # Allowed CORS origin (set to frontend domain in production)

# ── Operational Timeouts ──────────────────────────────────────────────────────
API_CLIENT_TIMEOUT=120.0                 # Timeout for AI provider API calls (seconds)
IMAGE_DOWNLOAD_TIMEOUT=30                # Timeout for downloading generated images (seconds)
GENERATE_THREAD_WORKERS=4                # Number of parallel generation threads
