# ==============================================================================
# Pixel Prompt v2 — Backend Environment Variables
#
# Copy to .env.deploy for SAM parameter overrides or set directly in Lambda.
# Variables without defaults are REQUIRED for operation.
# ==============================================================================

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-west-2                     # AWS region for S3/CloudFront/Bedrock
S3_BUCKET=                               # REQUIRED: S3 bucket for sessions and gallery
CLOUDFRONT_DOMAIN=                       # REQUIRED: CloudFront distribution domain for CDN URLs

# ── Gemini (Google) ───────────────────────────────────────────────────────────
GEMINI_ENABLED=true                      # Enable Gemini model
GEMINI_API_KEY=                          # Google Gemini API key
GEMINI_MODEL_ID=gemini-3.1-flash-image-preview  # Gemini image model

# ── Nova Canvas (Amazon Bedrock) ──────────────────────────────────────────────
# Auth uses the Lambda execution role's bedrock:InvokeModel permission.
# No API key is required.
NOVA_ENABLED=true                        # Enable Amazon Nova Canvas model
NOVA_MODEL_ID=amazon.nova-canvas-v1:0    # Bedrock model identifier

# ── OpenAI (DALL-E 3) ─────────────────────────────────────────────────────────
# DALL-E 3 is used for generation. Iteration/outpaint operations use
# gpt-image-1 internally because DALL-E 3 does not support images.edit.
OPENAI_ENABLED=true                      # Enable OpenAI model
OPENAI_API_KEY=                          # OpenAI API key
OPENAI_MODEL_ID=dall-e-3                 # OpenAI image generation model

# ── Adobe Firefly ─────────────────────────────────────────────────────────────
# Auth uses OAuth2 client credentials (no static API key).
FIREFLY_ENABLED=true                     # Enable Adobe Firefly model
FIREFLY_CLIENT_ID=                       # Firefly OAuth2 client ID
FIREFLY_CLIENT_SECRET=                   # Firefly OAuth2 client secret
FIREFLY_MODEL_ID=firefly-image-5         # Firefly model identifier

# ── Prompt Enhancement ────────────────────────────────────────────────────────
PROMPT_MODEL_PROVIDER=openai             # Provider for prompt enhancement (openai or google_gemini)
PROMPT_MODEL_ID=gpt-4o                   # Model ID for prompt enhancement
PROMPT_MODEL_API_KEY=                    # API key for prompt enhancement model

# ── Tier system (Phase 2026-04-08-paid-tier) ──────────────────────────────────
# Feature flags
AUTH_ENABLED=false                       # Enable Cognito auth + tier resolution
BILLING_ENABLED=false                    # Enable Stripe billing (requires AUTH_ENABLED=true)

# Cognito
COGNITO_USER_POOL_ID=                    # Cognito User Pool ID
COGNITO_USER_POOL_CLIENT_ID=             # Cognito App Client ID
COGNITO_DOMAIN=                          # Cognito Hosted UI domain prefix
COGNITO_REGION=us-west-2                 # Cognito region

# DynamoDB
USERS_TABLE_NAME=pixel-prompt-users      # DynamoDB table for tier and quota state

# Guest tracking
GUEST_TOKEN_SECRET=                      # HMAC secret for signing guest cookies
GUEST_GENERATE_LIMIT=1                   # /generate calls per guest per window
GUEST_WINDOW_SECONDS=3600                # Guest rolling window length (seconds)
GUEST_GLOBAL_LIMIT=5                     # Global cap on guest /generate calls per window
GUEST_GLOBAL_WINDOW_SECONDS=3600         # Global guest window length (seconds)

# Free tier
FREE_GENERATE_LIMIT=1                    # /generate calls per free user per window
FREE_REFINE_LIMIT=2                      # /iterate + /outpaint calls per free user per window
FREE_WINDOW_SECONDS=3600                 # Free tier rolling window length (seconds)

# Paid tier
PAID_DAILY_LIMIT=200                     # Refinement calls per paid user per day (operator-tuned)
PAID_WINDOW_SECONDS=86400                # Paid tier rolling window length (seconds)

# Stripe
STRIPE_SECRET_KEY=                       # Stripe API secret key
STRIPE_WEBHOOK_SECRET=                   # Stripe webhook signing secret
STRIPE_PRICE_ID=                         # Stripe price ID for paid subscription
STRIPE_SUCCESS_URL=                      # Redirect URL after successful checkout
STRIPE_CANCEL_URL=                       # Redirect URL after cancelled checkout
STRIPE_PORTAL_RETURN_URL=                # Return URL from Stripe customer portal

# ── Per-Model Daily Caps (Phase 2026-04-12-ops-safety) ────────────────────────
MODEL_GEMINI_DAILY_CAP=500               # Daily generation cap for Gemini
MODEL_NOVA_DAILY_CAP=500                 # Daily generation cap for Nova Canvas
MODEL_OPENAI_DAILY_CAP=500               # Daily generation cap for OpenAI
MODEL_FIREFLY_DAILY_CAP=500              # Daily generation cap for Firefly

# ── CAPTCHA (Cloudflare Turnstile) ───────────────────────────────────────────
CAPTCHA_ENABLED=false                    # Enable Turnstile CAPTCHA for guest /generate
TURNSTILE_SECRET_KEY=                    # Cloudflare Turnstile secret key

# ── Email Notifications (Amazon SES) ─────────────────────────────────────────
SES_ENABLED=false                        # Enable SES email notifications
SES_FROM_EMAIL=                          # Verified SES sender email address
SES_REGION=us-west-2                     # AWS region for SES

# ── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_ENABLED=false                      # Enable admin API endpoints (requires AUTH_ENABLED=true)

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=*                    # Allowed CORS origin (set to frontend domain in production)

# ── Operational Timeouts ──────────────────────────────────────────────────────
API_CLIENT_TIMEOUT=120.0                 # Timeout for AI provider API calls (seconds)
IMAGE_DOWNLOAD_TIMEOUT=30                # Timeout for downloading generated images (seconds)
GENERATE_THREAD_WORKERS=4                # Number of parallel generation threads
