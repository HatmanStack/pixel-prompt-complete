# Frontend Environment Variables Template
# Copy this file to .env and fill in your values
# Or run the deployment script: ./scripts/deploy.sh [environment]

# Backend API Gateway endpoint
# This is set automatically by deploy.sh or manually after backend deployment
# Format: https://{api-id}.execute-api.{region}.amazonaws.com/Prod
VITE_API_ENDPOINT=https://your-api-id.execute-api.us-west-2.amazonaws.com/Prod
